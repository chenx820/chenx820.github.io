2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z\"></path></svg></a>双量子比特门</h3>\n<h2 id=\"校准\" style=\"position:relative;\"><a href=\"#%E6%A0%A1%E5%87%86\" aria-label=\"校准 permalink\" class=\"gatsby-remark-autolink before\"><svg aria-hidden=\"true\" focusable=\"false\" height=\"16\" version=\"1.1\" viewBox=\"0 0 16 16\" width=\"16\"><path fill-rule=\"evenodd\" d=\"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z\"></path></svg></a>校准</h2>\n<h3 id=\"动机\" style=\"position:relative;\"><a href=\"#%E5%8A%A8%E6%9C%BA\" aria-label=\"动机 permalink\" class=\"gatsby-remark-autolink before\"><svg aria-hidden=\"true\" focusable=\"false\" height=\"16\" version=\"1.1\" viewBox=\"0 0 16 16\" width=\"16\"><path fill-rule=\"evenodd\" d=\"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z\"></path></svg></a>动机</h3>\n<h3 id=\"声子频率校准\" style=\"position:relative;\"><a href=\"#%E5%A3%B0%E5%AD%90%E9%A2%91%E7%8E%87%E6%A0%A1%E5%87%86\" aria-label=\"声子频率校准 permalink\" class=\"gatsby-remark-autolink before\"><svg aria-hidden=\"true\" focusable=\"false\" height=\"16\" version=\"1.1\" viewBox=\"0 0 16 16\" width=\"16\"><path fill-rule=\"evenodd\" d=\"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z\"></path></svg></a>声子频率校准</h3>","fields":{"slug":"/research/automatic-calibration-for-trapped-ion-systems"},"frontmatter":{"iframe":"//chenx820.github.io/research/baidu_calibration_20230831.pdf","title":"离子阱系统的自动校准","info":{"abstract":"离子阱量子计算的主要优势包括较长的量子相干时间、高精度单量子比特和双量子比特操作，以及系统内任意两个量子比特之间的高保真操作。在离子阱量子计算中，单量子比特操作通常涉及离子内部能级之间的跃迁，可以通过激光脉冲寻址目标离子来实现。然而，多量子比特操作依赖离子链的集体振动模式，也就是声子。离子位置、声子频率以及离子-声子相互作用强度等关键参数，与离子阱芯片结构、周围环境和囚禁势配置密切相关。为了实现高性能离子阱量子计算，精确校准系统参数至关重要。","links":[["黄晨、王敬博，“离子阱芯片参数修正方法、装置、电子设备及介质”，中国专利 CN117454997，2025 年授权。","https://patents.google.com/patent/CN117454997/zh"],["王敬博、黄晨，“离子阱芯片参数确定方法、装置、电子设备及介质”，中国专利 CN117371547，2024 年授权。","https://patents.google.com/patent/CN117371547/zh"],["王敬博、黄晨，“离子阱芯片参数校准方法、装置、电子设备及介质”，中国专利 CN117494829，2024 年授权。","https://patents.google.com/patent/CN117494829/zh"]],"collaborators":["百度研究院"]}}},"locales":{"edges":[{"node":{"ns":"common","data":"{\"global\":{\"name\":\"黄晨\"},\"nav\":{\"home\":\"首页\",\"about\":\"关于我\",\"research\":\"研究\",\"patents\":\"专利\",\"publications\":\"成果\",\"notes\":\"笔记\",\"gallery\":\"摄影集\",\"back-to-top\":\"返回顶部\",\"random-post\":\"随机文章\",\"random-note\":\"随机笔记\",\"tags\":\"标签\",\"institution\":\"机构\"},\"home\":{\"greeting\":\"你好，我是\",\"title\":\"黄晨\",\"subtitle\":\"探索量子世界\",\"resume\":\"下载简历\"},\"about\":{\"title\":\"关于我\",\"bio\":\"<p>你好，我是黄晨，即将在<cuhk><strong>香港中文大学（CUHK）</strong></cuhk>计算机科学与工程系攻读博士学位。<br/><br/>我热衷于通过理论研究与实验实现共同推动量子计算的发展。我的学术经历让我具备了扎实的物理基础，也积累了中性原子、离子阱和半导体量子比特等多种量子系统的实践经验。<br/><br/>我也从事量子线路相关研究。在北京量子信息科学研究院，我的研究聚焦于高效量子编译策略，尝试弥合硬件能力与实用、可扩展量子计算之间的距离。</p>\",\"heroCard\":{\"default\":\"我喜欢在跨学科研究与合作中不断拓展自己的知识边界。如果你想交流研究想法或潜在合作，欢迎通过<a href=\\\"mailto:chen.huang678@gmail.com\\\">邮件</a>联系我，也可以在 <a href=\\\"https://www.linkedin.com/in/chen-huang-820x\\\" target=\\\"_blank\\\" rel=\\\"noopener noreferrer\\\">LinkedIn</a> 上与我连接。\"},\"nameMeaning\":{\"chen\":\"我的名是<b>晨</b>，意思是“清晨”或“黎明”。这个含义很适合我，因为我是一个喜欢清晨安静时光的人。有趣的是，“晨”有时会被听成“橙”，所以朋友们也会亲切地叫我“橙子”。\",\"huang\":\"我的姓是<b>黄</b>，意为黄色。这个姓氏有深厚的历史和文化渊源，也常让人联想到中华文明传说中的始祖之一黄帝。\"},\"research\":{\"imperial\":\"我曾在帝国理工学院 <b>Controlled Quantum Dynamics Group</b> 攻读硕士，研究方向是半导体量子比特中的电荷噪声。通过实验与模拟，我尝试理解电荷噪声对量子比特性能的影响，并探索缓解这类噪声的策略。\",\"baqis\":\"与此同时，我也曾作为远程研究实习生参与北京量子信息科学研究院（BAQIS）<b>量子操作系统组</b>的研究，主要方向是中性原子平台上的量子编译。\"},\"news\":[\"2026-02-24 我们关于中性原子量子线路编译的论文被 DAC 2026 接收。\",\"2026-02-02 我开始在香港中文大学计算机科学与工程系担任研究助理。\",\"2026-01-26 我收到了香港中文大学计算机科学与工程系的博士正式录取。下一站，香港！\",\"2025-10-01 我以 Distinction 成绩获得帝国理工学院物理学硕士学位。\",\"2025-09-12 我的第五项专利完成提交。\",\"2025-06-18 我完成了硕士论文答辩，研究项目成绩为 85.15/100。\"]},\"research\":{\"title\":\"研究\",\"read-more\":\"阅读更多\",\"abstract\":\"摘要\",\"collaborators\":\"合作单位\",\"links\":\"链接与资源\"},\"patents\":{\"title\":\"专利\",\"see-patent\":\"查看专利\",\"inventors\":\"发明人\"},\"publications\":{\"title\":\"学术成果\",\"intro\":\"期刊论文、会议论文与专利。\",\"journal-papers\":\"期刊论文\",\"conference-papers\":\"会议论文\",\"preprints\":\"预印本\",\"patents\":\"专利\",\"talks\":\"报告与演示\"},\"footer\":{\"copyright\":\"© {{year}} 黄晨。保留所有权利。\"},\"notes\":{\"title\":\"笔记\",\"institution\":\"机构\",\"xiamen-foreign-language-school\":\"厦门外国语学校\",\"hust\":\"华中科技大学\",\"peking-university\":\"北京大学\",\"imperial\":\"帝国理工学院\",\"cuhk\":\"香港中文大学\",\"self-study\":\"自学\"},\"gallery\":{\"title\":\"摄影集\",\"highlight-title\":\"2024 旅程精选\",\"highlight-desc\":\"这一年的旅程带我穿过许多国家的壮阔风景与鲜活城市。\",\"photography\":\"摄影\",\"show-all\":\"查看全部\"},\"common\":{\"share-on\":\"分享到\",\"edit-on-github\":\"在 GitHub 上编辑文章\"},\"notFound\":{\"title\":\"404：页面未找到\",\"heading\":\"糟糕，看来你迷路了！\",\"body\":\"要不要回去？或者<notesLink>读点笔记</notesLink>。\"}}","language":"zh"}}]}},"pageContext":{"slug":"/research/automatic-calibration-for-trapped-ion-systems","language":"zh","i18n":{"language":"zh","languages":["en","zh"],"defaultLanguage":"en","generateDefaultLanguagePage":false,"routed":true,"originalPath":"/research/automatic-calibration-for-trapped-ion-systems/","path":"zh/research/automatic-calibration-for-trapped-ion-systems/"}}},"staticQueryHashes":["264526366"],"slicesMap":{}}